}

/* 骞虫澘璁惧Grid妯″紡锛氫娇鐢ㄥ崟鍒楀竷灞€锛屽拰鎵嬫満绔繚鎸佷竴鑷?*/
@media (min-width: 768px) and (max-width: 1279px) {
    #main-grid[data-layout-mode="grid"] {
        grid-template-columns: 1fr !important;
        grid-template-rows: auto 1fr auto !important;
    }
    
