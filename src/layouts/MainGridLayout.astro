---
import BackToTop from "@components/control/BackToTop.astro";
import FloatingTOC from "@components/control/FloatingTOC.astro";
import Footer from "@components/Footer.astro";
import RightSideBar from "@components/layout/RightSideBar.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import FullscreenWallpaper from "../components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "../components/misc/IconifyLoader.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TypewriterText from "../components/TypewriterText.astro";
import TOC from "../components/widget/TOC.astro";
import {
	fullscreenWallpaperConfig,
	siteConfig,
} from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	// BANNER_HEIGHT_HOME,
	// MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";

// TOC妯″紡閰嶇疆
const tocMode = siteConfig.toc.mode || "float";
const isFloatTOC = tocMode === "float";
const isSidebarTOC = tocMode === "sidebar";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
	headings?: MarkdownHeading[];
}

// 绫诲瀷瀹堝崼鍑芥暟
// const isBannerSrcObject = (
// 	src:
// 		| string
// 		| string[]
// 		| { desktop?: string | string[]; mobile?: string | string[] },
// ): src is { desktop?: string | string[]; mobile?: string | string[] } => {
// 	return (
// 		typeof src === "object" &&
// 		src !== null &&
// 		!Array.isArray(src) &&
// 		("desktop" in src || "mobile" in src)
// 	);
// };

// 鑾峰彇banner鍥剧墖鐨勮緟鍔╁嚱鏁?
const getBannerImages = async () => {
	let bannerSrc = siteConfig.banner.src;

	// 濡傛灉鍚敤浜嗗浘鐗嘇PI锛岃幏鍙朅PI鍥剧墖
	if (siteConfig.banner.imageApi?.enable && siteConfig.banner.imageApi?.url) {
		try {
			const response = await fetch(siteConfig.banner.imageApi.url);
			const text = await response.text();
			const apiImages = text.split("\n").filter((line) => line.trim());

			if (apiImages.length > 0) {
				bannerSrc = apiImages;
			}
		} catch (error) {
			console.warn("Failed to fetch images from API:", error);
		}
	}

	if (
		typeof bannerSrc === "object" &&
		bannerSrc !== null &&
		!Array.isArray(bannerSrc) &&
		("desktop" in bannerSrc || "mobile" in bannerSrc)
	) {
		const srcObj = bannerSrc as {
			desktop?: string | string[];
			mobile?: string | string[];
		};
		return {
			desktop: srcObj.desktop || srcObj.mobile || "",
			mobile: srcObj.mobile || srcObj.desktop || "",
		};
	}
	// 濡傛灉鏄瓧绗︿覆鎴栧瓧绗︿覆鏁扮粍锛屽悓鏃剁敤浜庢闈㈢鍜岀Щ鍔ㄧ
	return {
		desktop: bannerSrc,
		mobile: bannerSrc,
	};
};

const bannerImages = await getBannerImages();

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	postSlug,
	headings = [],
} = Astro.props;
const hasBannerCredit = siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

// 妫€鏌ユ槸鍚︿负棣栭〉
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
const showHomeText = siteConfig.banner.homeText?.enable && isHomePage;
// 鎵嬫満绔潪棣栭〉涓嶆樉绀篵anner鐨凜SS绫?
const mobileNonHomeBannerClass = !isHomePage ? "mobile-hide-banner" : "";

// 璁＄畻涓诲唴瀹瑰尯鍩熶綅缃紝鑰冭檻鎵嬫満绔潪棣栭〉鏃禸anner琚殣钘?
// 褰撻粯璁ゆā寮忎负 banner 鏃讹紝浣跨敤banner楂樺害锛涘惁鍒欎娇鐢ㄩ《鏍忛珮搴?
// 璁╀富鍐呭鍖哄煙绱ц创娉㈡氮绾夸笅鏂癸紝娉㈡氮绾块珮搴︾害涓?0-15vh锛屾墍浠ヤ富鍐呭浠巄anner椤堕儴寮€濮?
const mainPanelTop =
	siteConfig.wallpaperMode.defaultMode === "banner"
		? `${BANNER_HEIGHT}vh`
		: "5.5rem";
// const mobileNonHomeMainTop = !isHomePage ? "5.5rem" : mainPanelTop;

// 褰撻粯璁ゆā寮忎笉鏄?banner 鏃讹紝涓诲唴瀹瑰尯鍩熷簲璇ュ缁堜粠椤舵爮涓嬮潰寮€濮?
const finalMainPanelTop =
	siteConfig.wallpaperMode.defaultMode === "banner" ? mainPanelTop : "5.5rem";

// 妫€鏌ュ乏渚ц竟鏍忔槸鍚︽湁缁勪欢
const hasLeftSidebarComponents =
	widgetManager.getComponentsByPosition("top", "left", "desktop").length > 0 ||
	widgetManager.getComponentsByPosition("sticky", "left", "desktop").length > 0;

// 妫€鏌ュ彸渚ц竟鏍忔槸鍚︽湁缁勪欢
const hasRightSidebarComponents =
	widgetManager.getComponentsByPosition("top", "right", "desktop").length > 0 ||
	widgetManager.getComponentsByPosition("sticky", "right", "desktop").length > 0;

// 妫€鏌ユ墜鏈虹 drawer 鏄惁鏈夌粍浠?
const hasMobileDrawerComponents =
	widgetManager.getComponentsByPosition("top", "drawer", "mobile").length > 0 ||
	widgetManager.getComponentsByPosition("sticky", "drawer", "mobile").length > 0;

// 骞虫澘绔槸鍚︽湁缁勪欢锛堣€冭檻鑷姩绉诲姩閫昏緫锛?
const hasTabletLeftSidebarComponents =
	widgetManager.getComponentsByPosition("top", "left", "tablet").length > 0 ||
	widgetManager.getComponentsByPosition("sticky", "left", "tablet").length > 0;

// 妫€鏌ヤ晶杈规爮鏄惁鍚敤锛屽姩鎬佽皟鏁寸綉鏍煎竷灞€
const mobileShowSidebar = hasMobileDrawerComponents;
const tabletShowSidebar = hasTabletLeftSidebarComponents;
const desktopShowSidebar = hasLeftSidebarComponents || hasRightSidebarComponents;

// 妗岄潰绔晶杈规爮鏈€缁堟樉绀虹姸鎬侊紙鑰冭檻鏄惁鏈夌粍浠讹級
const desktopShowLeftSidebar = hasLeftSidebarComponents;
const desktopShowRightSidebar = hasRightSidebarComponents;

// 骞虫澘绔晶杈规爮鏈€缁堟樉绀虹姸鎬?
const tabletShowLeftSidebar = hasTabletLeftSidebarComponents;
// 濡傛灉宸︿晶鏈夌粍浠讹紝鍒欏钩鏉跨涓嶆樉绀哄彸渚т晶鏍忥紱鍙湁褰撳乏渚т负绌轰笖鍙充晶鏈夌粍浠舵椂锛屾墠鏄剧ず鍙充晶渚ф爮锛堜細琚Щ鍒板乏渚э級
// 娉ㄦ剰锛氱幇鍦?getComponentsByPosition("left", "tablet") 宸茬粡鍖呭惈浜嗚繖涓€昏緫
const tabletShowRightSidebar = false; // 骞虫澘绔笉鍐嶆湁鐙珛鐨勫彸渚ф爮锛屽鏋滃彸绉诲乏浜嗭紝瀹冨氨鍦?tabletShowLeftSidebar 涓樉绀?
const tabletAnySidebar = tabletShowLeftSidebar;

// 妫€鏌ラ粯璁ゅ竷灞€妯″紡锛屽鏋滄槸 grid 妯″紡锛屽彸渚ц竟鏍忓垵濮嬪氨搴旇闅愯棌
const defaultPostListLayout = siteConfig.postListLayout?.defaultMode || "list";
const initialRightSidebarHidden = defaultPostListLayout === "grid";

// 鍔ㄦ€佺綉鏍煎竷灞€绫诲悕 - 鏍规嵁渚ц竟鏍忔ā寮忓拰鏄惁鏈夌粍浠惰皟鏁村垪瀹?
let desktopGridCols = "lg:grid-cols-1";
if (desktopShowLeftSidebar && desktopShowRightSidebar) {
	desktopGridCols = "lg:grid-cols-[17.5rem_1fr_17.5rem]";
} else if (desktopShowLeftSidebar) {
	desktopGridCols = "lg:grid-cols-[17.5rem_1fr]";
} else if (desktopShowRightSidebar) {
	desktopGridCols = "lg:grid-cols-[1fr_17.5rem]";
}

const gridCols = `
	${mobileShowSidebar ? "grid-cols-1" : "grid-cols-1"}
	${tabletAnySidebar ? "md:grid-cols-[17.5rem_1fr]" : "md:grid-cols-1"}
	${desktopGridCols}
`
	.trim()
	.replace(/\s+/g, " ");

// 渚ц竟鏍忓鍣ㄧ被鍚?- 濮嬬粓鍦ㄥ乏渚?
const sidebarClass = `
	onload-animation
	${mobileShowSidebar && hasMobileDrawerComponents ? "block" : "hidden"}
	${tabletShowLeftSidebar ? "md:block md:mb-4 md:max-w-[17.5rem]" : "md:hidden"}
	${desktopShowLeftSidebar ? "lg:block lg:mb-4 lg:row-start-1 lg:row-end-2 lg:max-w-[17.5rem] lg:col-start-1 lg:col-end-2" : "lg:hidden"}
`
	.trim()
	.replace(/\s+/g, " ");

// 鍙充晶杈规爮瀹瑰櫒绫诲悕
// 鎵嬫満绔細闅愯棌锛堟墜鏈虹鍙€氳繃 drawer 鏄剧ず缁勪欢锛?
// 骞虫澘绔細鏍规嵁绠€鍖栭€昏緫鏄剧ず锛堝彧鏈夊綋宸︿晶涓虹┖鏃舵墠鏄剧ず骞剁Щ鍒板乏渚э級
// 妗岄潰绔細瀹氫綅鍒扮綉鏍兼渶鍚庝竴鍒楋紙鍙充晶锛?
// 濡傛灉榛樿鏄?grid 妯″紡锛屽垵濮嬪氨闅愯棌
const rightSidebarClass = `
	onload-animation
	hidden
	${tabletShowRightSidebar ? "md:block md:mb-4 md:max-w-[17.5rem]" : "md:hidden"}
	${desktopShowRightSidebar ? `lg:block lg:mb-4 lg:row-start-1 lg:row-end-2 lg:max-w-[17.5rem] ${desktopShowLeftSidebar ? "lg:col-start-3 lg:col-end-4" : "lg:col-start-2 lg:col-end-3"} lg:col-span-1` : "lg:hidden"}
	${initialRightSidebarHidden ? "hidden-in-grid-mode" : ""}
`
	.trim()
	.replace(/\s+/g, " ");

// 涓诲唴瀹瑰尯鍩熺被鍚?- 鏍规嵁渚ц竟鏍忔ā寮忚皟鏁磄rid-column
// 骞虫澘璁惧鍜屾墜鏈虹锛氫富鍐呭鍦ㄦ渶涓婃柟row-1锛屼晶杈规爮鍦ㄤ笅鏂?
// 妗岄潰绔細涓诲唴瀹瑰拰渚ц竟鏍忓苟鎺掓樉绀?
let desktopMainPos = "lg:col-span-1";
if (desktopShowLeftSidebar && desktopShowRightSidebar) {
	desktopMainPos = "lg:col-start-2 lg:col-end-3";
} else if (desktopShowLeftSidebar) {
	desktopMainPos = "lg:col-start-2 lg:col-end-3";
} else if (desktopShowRightSidebar) {
	desktopMainPos = "lg:col-start-1 lg:col-end-2";
}

const mainContentClass = `
	transition-swup-fade overflow-hidden w-full
	col-span-1 row-start-1 row-end-2
	${tabletAnySidebar ? "md:col-start-2 md:col-end-3" : "md:col-start-1 md:col-end-2"}
	${desktopShowSidebar ? desktopMainPos : "lg:col-span-1"}
`
	.trim()
	.replace(/\s+/g, " ");

// 妫€鏌ユ槸鍚﹀簲璇ュ惎鐢ㄥ崐閫忔槑鏁堟灉锛堝綋榛樿妯″紡涓?fullscreen 鏃讹級
const shouldEnableTransparency =
	siteConfig.wallpaperMode.defaultMode === "fullscreen";

// 涓虹粍浠舵坊鍔犲崐閫忔槑鏁堟灉鐨凜SS绫?
const transparentClass = shouldEnableTransparency
	? "wallpaper-transparent"
	: "";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} postSlug={postSlug}>

<script type="module" is:inline define:vars={{navbarTransparentMode: siteConfig.banner?.navbar?.transparentMode || "semi", defaultWallpaperMode: siteConfig.wallpaperMode.defaultMode, defaultPostListLayout: siteConfig.postListLayout?.defaultMode || "list", allowPostListSwitch: siteConfig.postListLayout?.allowSwitch ?? true, BANNER_HEIGHT: BANNER_HEIGHT, pageScaling: siteConfig.pageScaling}}>

	const getCurrentLayout = () => {
		if (!allowPostListSwitch) return 'list';
		const savedLayout = localStorage.getItem('postListLayout');
		if (savedLayout === 'grid' || savedLayout === 'list') {
			return savedLayout;
		}
		return defaultPostListLayout;
	};

	if (!allowPostListSwitch) {
		try {
			localStorage.setItem('postListLayout', 'list');
			sessionStorage.setItem('postListLayout', 'list');
		} catch (_error) {
			// Ignore storage access errors in restricted environments.
		}
	}

	// 绔嬪嵆鎵ц锛屽湪椤甸潰娓叉煋鍓嶅簲鐢ㄥ绾告ā寮忓拰甯冨眬妯″紡锛岄伩鍏嶉棯鐑?
	(function() {
		const wallpaperMode = localStorage.getItem('wallpaperMode') || defaultWallpaperMode;
		const body = document.body;
		
		// 瀹氫箟 banner 楂樺害甯搁噺锛堜笌 constants.ts 淇濇寔涓€鑷达級
		// const BANNER_HEIGHT = 35;
		// const BANNER_HEIGHT_EXTEND = 30;
		// const BANNER_HEIGHT_HOME = BANNER_HEIGHT + BANNER_HEIGHT_EXTEND;
		// const MAIN_PANEL_OVERLAPS_BANNER_HEIGHT = 3.5;
		
		// 绔嬪嵆搴旂敤 body 绫伙紝纭繚棣栨娓叉煋灏辨槸姝ｇ‘鐨勭姸鎬?
		switch(wallpaperMode) {
			case 'banner':
				body.classList.add('enable-banner');
				body.classList.remove('wallpaper-transparent', 'no-banner-mode');
				break;
			case 'fullscreen':
				body.classList.remove('enable-banner');
				body.classList.add('wallpaper-transparent', 'no-banner-mode');
				break;
			case 'none':
				body.classList.remove('enable-banner', 'wallpaper-transparent');
				body.classList.add('no-banner-mode');
				break;
		}
		
		// 绔嬪嵆璋冩暣涓诲唴瀹瑰尯鍩熶綅缃拰甯冨眬妯″紡锛堥伩鍏嶉棯鐑佸拰浣嶇疆閿欒锛?
		// 浣跨敤 requestAnimationFrame 纭繚 DOM 鍑嗗濂?
		requestAnimationFrame(function() {
			const mainContent = document.querySelector('.absolute.w-full.z-30.pointer-events-none');
			if (mainContent) {
				if (wallpaperMode === 'banner') {
					// 璁╀富鍐呭鍖哄煙浠巄anner椤堕儴寮€濮嬶紝杩欐牱娉㈡氮绾夸細鑷劧瑕嗙洊鍐呭涓婇儴
					mainContent.style.top = `${BANNER_HEIGHT}vh`;
				} else {
					// fullscreen 鎴?none 妯″紡
					mainContent.style.top = '5.5rem';
				}
			}
			
			// 绔嬪嵆搴旂敤甯冨眬妯″紡锛岄伩鍏嶉棯鐑?
			const mainGrid = document.getElementById('main-grid');
			if (mainGrid) {
				const currentLayout = getCurrentLayout();
				mainGrid.setAttribute('data-layout-mode', currentLayout);
				
				// 鏍规嵁甯冨眬妯″紡鏄剧ず鎴栭殣钘忓彸渚ц竟鏍?
				const rightSidebar = document.querySelector('.right-sidebar-container');
				if (rightSidebar) {
					if (currentLayout === 'grid') {
						rightSidebar.classList.add('hidden-in-grid-mode');
					} else {
						rightSidebar.classList.remove('hidden-in-grid-mode');
					}
				}
				
				// 鍚屾椂鏇存柊鏂囩珷鍒楄〃瀹瑰櫒鐨凜SS绫?
				const postListContainer = document.getElementById('post-list-container');
				if (postListContainer) {
					postListContainer.classList.remove('list-mode', 'grid-mode');
					
					if (currentLayout === 'grid') {
						postListContainer.classList.add('grid-mode');
						postListContainer.classList.add('grid', 'grid-cols-1', 'lg:grid-cols-2', 'gap-6');
						postListContainer.classList.remove('flex', 'flex-col');
					} else {
						postListContainer.classList.add('list-mode');
						postListContainer.classList.add('flex', 'flex-col');
						postListContainer.classList.remove('grid', 'grid-cols-1', 'lg:grid-cols-2', 'gap-6');
					}
				}
			}
		});
	})();
	
	// 鏍规嵁澹佺焊妯″紡鍔ㄦ€佽缃?banner 鍜屽叏灞忓绾哥殑鏄剧ず
	// const wallpaperMode = localStorage.getItem('wallpaperMode') || defaultWallpaperMode;
	
	// 鍦?DOM 鍔犺浇鍚庢墽琛?
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', applyWallpaperMode);
	} else {
		applyWallpaperMode();
	}
	
	function applyWallpaperMode() {
		var wallpaperMode = localStorage.getItem('wallpaperMode') || defaultWallpaperMode;
		var bannerWrapper = document.getElementById('banner-wrapper');
		var fullscreenWallpaper = document.querySelector('[data-fullscreen-wallpaper]');
		var navbar = document.getElementById('navbar');
		var body = document.body;
		var mainContent = document.querySelector('.absolute.w-full.z-30.pointer-events-none');
		var tocWrapper = document.getElementById('toc-wrapper');
		
		// 寮哄埗閲嶆帓浠ョ‘淇濇牱寮忔纭簲鐢?
		var forceReflow = function() {
			void document.body.offsetHeight;
		};
		
		switch(wallpaperMode) {
			case 'banner':
				// 鏄剧ず banner锛岄殣钘忓叏灞忓绾?
				if (bannerWrapper) {
					bannerWrapper.style.display = 'block';
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = 'none';
				}
				// 鎭㈠ TOC 鍦?banner 妯″紡涓嬬殑闅愯棌鐘舵€侊紝璁╂粴鍔ㄩ€昏緫鎺ョ
				if (tocWrapper) {
					const scrollTop = document.documentElement.scrollTop;
					const bannerHeight = window.innerHeight * (BANNER_HEIGHT / 100);
					if (scrollTop <= bannerHeight) {
						tocWrapper.classList.add('toc-hide');
					}
				}
				// 鍏堢Щ闄ody绫伙紝閬垮厤CSS鍐茬獊
				body.classList.remove('wallpaper-transparent');
				body.classList.remove('no-banner-mode');
				// 寮哄埗閲嶆帓
				forceReflow();
				// 绉婚櫎鍐呰仈鏍峰紡锛岃CSS瀹屽叏鎺ョ
				if (mainContent) {
					mainContent.style.removeProperty('top');
				}
				// 鍐嶆坊鍔爀nable-banner绫?
				body.classList.add('enable-banner');
				// navbar 鎭㈠鍘熷閫忔槑妯″紡锛堜粠 config 璇诲彇锛?
				if (navbar) {
					navbar.removeAttribute('data-dynamic-transparent');
					// 鎭㈠ config 涓缃殑 data-transparent-mode
					navbar.setAttribute('data-transparent-mode', navbarTransparentMode);
					// 濡傛灉鏄?semifull 妯″紡锛岄噸鏂板垵濮嬪寲婊氬姩妫€娴?
					if (navbarTransparentMode === 'semifull' && window.initSemifullScrollDetection) {
						window.initSemifullScrollDetection();
					}
				}
				// 寮哄埗閲嶆帓浠ョ‘淇滳SS鍙橀噺姝ｇ‘鏇存柊
				forceReflow();
				break;
				
			case 'fullscreen':
				// 闅愯棌 banner锛屾樉绀哄叏灞忓绾?
				if (bannerWrapper) {
					bannerWrapper.style.display = 'none';
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = 'block';
				}
				// 鍦ㄥ叏灞忔ā寮忎笅濮嬬粓鏄剧ず TOC
				if (tocWrapper) {
					tocWrapper.classList.remove('toc-hide');
				}
				// 鍏堢Щ闄ody绫伙紝閬垮厤CSS鍐茬獊
				body.classList.remove('enable-banner');
				// 寮哄埗閲嶆帓
				forceReflow();
				// 绉婚櫎鍐呰仈鏍峰紡锛岃CSS瀹屽叏鎺ョ
				if (mainContent) {
					mainContent.style.removeProperty('top');
				}
				// 鍐嶆坊鍔爓allpaper-transparent鍜宯o-banner-mode绫?
				body.classList.add('wallpaper-transparent');
				body.classList.add('no-banner-mode');
				// navbar 寮哄埗璁剧疆涓?semi 閫忔槑妯″紡锛堝拷鐣?config 閰嶇疆锛?
				if (navbar) {
					navbar.setAttribute('data-dynamic-transparent', 'semi');
					// 寮哄埗绉婚櫎 config 涓殑 data-transparent-mode 褰卞搷
					navbar.removeAttribute('data-transparent-mode');
				}
				// 寮哄埗閲嶆帓浠ョ‘淇滳SS鍙橀噺姝ｇ‘鏇存柊
				forceReflow();
				break;
				
			case 'none':
				// 闅愯棌鎵€鏈夊绾?
				if (bannerWrapper) {
					bannerWrapper.style.display = 'none';
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = 'none';
				}
				// 鍦ㄦ棤澹佺焊妯″紡涓嬩篃濮嬬粓鏄剧ず TOC
				if (tocWrapper) {
					tocWrapper.classList.remove('toc-hide');
				}
				// 鍏堢Щ闄ody绫伙紝閬垮厤CSS鍐茬獊
				body.classList.remove('enable-banner');
				body.classList.remove('wallpaper-transparent');
				// 寮哄埗閲嶆帓
				forceReflow();
				// 绉婚櫎鍐呰仈鏍峰紡锛岃CSS瀹屽叏鎺ョ
				if (mainContent) {
					mainContent.style.removeProperty('top');
				}
				// 鍐嶆坊鍔爊o-banner-mode绫?
				body.classList.add('no-banner-mode');
				// navbar 寮哄埗璁剧疆涓轰笉閫忔槑锛堝拷鐣?config 閰嶇疆锛?
				if (navbar) {
					navbar.setAttribute('data-dynamic-transparent', 'none');
					// 寮哄埗绉婚櫎 config 涓殑 data-transparent-mode 褰卞搷
					navbar.removeAttribute('data-transparent-mode');
				}
				// 寮哄埗閲嶆帓浠ョ‘淇滳SS鍙橀噺姝ｇ‘鏇存柊
				forceReflow();
				break;
		}
	}
	
	// 鐩戝惉澹佺焊妯″紡鍙樺寲锛岀珛鍗冲簲鐢紙涓嶉噸杞介〉闈級
	window.addEventListener('wallpaper-mode-change', function(_event) {
		applyWallpaperMode();
	});
	
	// 鏀寔 Swup 椤甸潰杩囨浮 - 鍦ㄥ唴瀹规浛鎹箣鍓嶅氨搴旂敤甯冨眬锛岄伩鍏嶉棯鐑?
	function setupSwupLayoutSync() {
		// @ts-ignore
		if (typeof window !== 'undefined' && window.swup) {
			// 鍏抽敭锛氬湪 content:replace 涔嬪墠锛坅nimation:out:start锛夊氨鍑嗗濂藉竷灞€鐘舵€?
			// @ts-ignore
			window.swup.hooks.on('animation:out:start', function() {
				// 淇濆瓨褰撳墠甯冨眬鐘舵€侊紝浠ヤ究鍦ㄦ柊椤甸潰涓珛鍗冲簲鐢?
				const savedLayout = getCurrentLayout();
				if (savedLayout) {
					// @ts-ignore
					window.__pendingLayoutMode = savedLayout;
				}
			});
			
			// 鍦ㄥ唴瀹规浛鎹㈠悗绔嬪嵆搴旂敤甯冨眬锛屼笉绛夊緟鍏朵粬鑴氭湰
			// @ts-ignore
			window.swup.hooks.on('content:replace', function() {
				const mainGrid = document.getElementById('main-grid');
				if (mainGrid) {
					// @ts-ignore
					const currentLayout = window.__pendingLayoutMode === 'grid' || window.__pendingLayoutMode === 'list' ? window.__pendingLayoutMode : getCurrentLayout();
					mainGrid.setAttribute('data-layout-mode', currentLayout);
					
					const rightSidebar = document.querySelector('.right-sidebar-container');
					if (rightSidebar) {
						if (currentLayout === 'grid') {
							rightSidebar.classList.add('hidden-in-grid-mode');
						} else {
							rightSidebar.classList.remove('hidden-in-grid-mode');
						}
					}
					
					// 鍏抽敭锛氬悓鏃舵洿鏂版枃绔犲垪琛ㄥ鍣ㄧ殑CSS绫?
					const postListContainer = document.getElementById('post-list-container');
					if (postListContainer) {
						// 绉婚櫎鐜版湁甯冨眬绫?
						postListContainer.classList.remove('list-mode', 'grid-mode');
						
						if (currentLayout === 'grid') {
							postListContainer.classList.add('grid-mode');
							postListContainer.classList.add('grid', 'grid-cols-1', 'lg:grid-cols-2', 'gap-6');
							postListContainer.classList.remove('flex', 'flex-col');
						} else {
							postListContainer.classList.add('list-mode');
							postListContainer.classList.add('flex', 'flex-col');
							postListContainer.classList.remove('grid', 'grid-cols-1', 'lg:grid-cols-2', 'gap-6');
						}
					}
					
					// 娓呴櫎涓存椂鐘舵€?
					// @ts-ignore
					delete window.__pendingLayoutMode;
				}
			});
			
			return true;
		}
		return false;
	}
	
	// 灏濊瘯绔嬪嵆璁剧疆锛屽鏋滃け璐ュ垯寤惰繜閲嶈瘯
	if (!setupSwupLayoutSync()) {
		const checkSwup = setInterval(function() {
			if (setupSwupLayoutSync()) {
				clearInterval(checkSwup);
			}
		}, 50);
		
		setTimeout(function() {
			clearInterval(checkSwup);
		}, 2000);
	}
	
	// 鏀寔 Swup 椤甸潰杩囨浮
	document.addEventListener('swup:page:view', function() {
		applyWallpaperMode();
		
		// 鍦⊿wup椤甸潰鍒囨崲鏃朵篃瑕侀噸鏂板簲鐢ㄥ竷灞€妯″紡
		requestAnimationFrame(function() {
			const mainGrid = document.getElementById('main-grid');
			if (mainGrid) {
				const currentLayout = getCurrentLayout();
				mainGrid.setAttribute('data-layout-mode', currentLayout);
				
				if (currentLayout === 'grid') {
					const rightSidebar = document.querySelector('.right-sidebar-container');
					if (rightSidebar) {
						rightSidebar.classList.add('hidden-in-grid-mode');
					}
				} else {
					const rightSidebar = document.querySelector('.right-sidebar-container');
					if (rightSidebar) {
						rightSidebar.classList.remove('hidden-in-grid-mode');
					}
				}
			}
		});
	});
	// 鍦ㄩ〉闈㈠畬鍏ㄥ姞杞藉悗锛屽啀娆＄‘璁ゅ竷灞€妯″紡鏄惁姝ｇ‘
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', function() {
			const mainGrid = document.getElementById('main-grid');
			if (mainGrid) {
				const currentLayout = getCurrentLayout();
				mainGrid.setAttribute('data-layout-mode', currentLayout);
				
				if (currentLayout === 'grid') {
					const rightSidebar = document.querySelector('.right-sidebar-container');
					if (rightSidebar) {
						rightSidebar.classList.add('hidden-in-grid-mode');
					}
				}
			}
		});
	}
</script>

<!-- 鍏ㄥ睆澹佺焊 - 濮嬬粓娓叉煋锛岄€氳繃 JS 鎺у埗鏄剧ず闅愯棌 -->
