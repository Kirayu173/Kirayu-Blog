/* 绉诲姩绔殫鑹叉ā寮忎紭鍖?*/
@media (max-width: 1279px) and (prefers-color-scheme: dark) {
    .banner-text-overlay {
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.8) 0%,
            rgba(0, 0, 0, 0.4) 50%,
            transparent 100%
        );
    }

    .banner-title {
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8);
    }

    .banner-subtitle {
        text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.7);
    }
}

/* 姘存尝绾规樉绀轰紭鍖?*/
.waves {
    /* 纭繚姘存尝绾瑰畬鏁存樉绀?*/
    overflow: visible;
    z-index: 5;
    /* 纭欢鍔犻€燂紝纭繚涓庤儗鏅悓姝ユ覆鏌?*/
    transform: translateZ(0);
    will-change: transform;
    /* 纭繚涓庨〉闈㈣儗鏅湪鍚屼竴鍚堟垚灞?*/
    contain: layout style paint;
}

.waves svg {
    /* 纭繚SVG瀹屾暣娓叉煋 */
    width: 100%;
    height: 100%;
    display: block;
    /* SVG纭欢鍔犻€?*/
    transform: translateZ(0);
    backface-visibility: hidden;
}

/* 娉㈡氮濉厖鑹蹭富棰樺垏鎹紭鍖?*/
.waves use {
    /* 纭繚濉厖鑹蹭笌椤甸潰鑳屾櫙鍚屾鏇存柊 */
    will-change: fill;
}

/* 娉㈡氮涓庤儗鏅悓姝ュ垏鎹紭鍖?- 瑙ｅ喅浜ょ晫绾块棯鐑?*/
#header-waves {
    /* 纭繚娉㈡氮瀹瑰櫒涓庨〉闈㈣儗鏅湪鍚屼竴鍚堟垚灞?*/
    isolation: isolate;
    /* 寮哄埗閲嶇粯锛岀‘淇濅笌body鑳屾櫙鍚屾 */
    contain: layout style paint;
    /* 绮剧‘瀵归綈 */
    margin-bottom: -1px;
}

/* 涓婚鍒囨崲鏃剁殑棰濆淇濇姢 */
.theme-changing #header-waves,
.theme-changing #header-waves svg,
.theme-changing #header-waves use {
    /* 鍦ㄤ富棰樺垏鎹㈡湡闂寸鐢ㄦ墍鏈夊彲鑳界殑娓叉煋寤惰繜 */
    will-change: auto;
    transform: translateZ(0);
    backface-visibility: hidden;
}

/* 绉诲姩绔按娉㈢汗鐗规畩浼樺寲 */
@media (max-width: 1279px) {
    #header-waves {
        /* 纭繚姘存尝绾瑰鍣ㄤ笉琚鍓?*/
        overflow: visible;
        z-index: 5;
        /* 姘存尝绾瑰揩閫熸秷澶卞姩鐢?*/
        transition: transform 0.3s ease-in, opacity 0.2s ease-in;
    }
    
    /* 褰揵anner闅愯棌鏃讹紝姘存尝绾瑰揩閫熸秷澶?*/
    .mobile-hide-banner #header-waves {
        transform: translateY(-100%);
        opacity: 0;
        /* 姘存尝绾规瘮banner鏇村揩娑堝け */
        transition: transform 0.25s ease-in, opacity 0.15s ease-in;
    }
    
    .waves svg {
        /* 绉诲姩绔疭VG浼樺寲 */
        min-height: 60px;
    }
    
    /* 纭繚姘存尝绾瑰湪banner搴曢儴姝ｇ‘瀹氫綅 */
    .waves {
        bottom: -1px !important;
        position: absolute !important;
    }
}

