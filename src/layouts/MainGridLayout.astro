/* ж°ҙжіўзә№жҳҫзӨәдјҳеҢ?*/
.waves {
    /* зЎ®дҝқж°ҙжіўзә№е®Ңж•ҙжҳҫзӨ?*/
    overflow: visible;
    z-index: 5;
    /* зЎ¬д»¶еҠ йҖҹпјҢзЎ®дҝқдёҺиғҢжҷҜеҗҢжӯҘжёІжҹ?*/
    transform: translateZ(0);
    will-change: transform;
    /* зЎ®дҝқдёҺйЎөйқўиғҢжҷҜеңЁеҗҢдёҖеҗҲжҲҗеұ?*/
    contain: layout style paint;
}

.waves svg {
    /* зЎ®дҝқSVGе®Ңж•ҙжёІжҹ“ */
    width: 100%;
    height: 100%;
    display: block;
    /* SVGзЎ¬д»¶еҠ йҖ?*/
    transform: translateZ(0);
    backface-visibility: hidden;
}

/* жіўжөӘеЎ«е……иүІдё»йўҳеҲҮжҚўдјҳеҢ?*/
.waves use {
    /* зЎ®дҝқеЎ«е……иүІдёҺйЎөйқўиғҢжҷҜеҗҢжӯҘжӣҙж–° */
    will-change: fill;
}

/* жіўжөӘдёҺиғҢжҷҜеҗҢжӯҘеҲҮжҚўдјҳеҢ?- и§ЈеҶідәӨз•Ңзәҝй—Әзғ?*/
#header-waves {
    /* зЎ®дҝқжіўжөӘе®№еҷЁдёҺйЎөйқўиғҢжҷҜеңЁеҗҢдёҖеҗҲжҲҗеұ?*/
    isolation: isolate;
    /* ејәеҲ¶йҮҚз»ҳпјҢзЎ®дҝқдёҺbodyиғҢжҷҜеҗҢжӯҘ */
    contain: layout style paint;
